# Eventful environment — copy to .env and fill in. Bun loads .env automatically.
# .env is gitignored; never commit real keys.

# Ticketmaster Discovery API (primary event source).
# Get a free Consumer Key at https://developer.ticketmaster.com/ (My Apps).
# The Consumer Key is sent as the `apikey` query param on Discovery requests.
TICKETMASTER_API_KEY=

# Consumer Secret — only needed for the OAuth product.
TICKETMASTER_API_SECRET=

# Optional: override the DuckDB database path (defaults to data/eventful.duckdb).
# EVENTFUL_DB_PATH=
